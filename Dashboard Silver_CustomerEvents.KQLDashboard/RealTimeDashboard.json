      },
      "text": "_Base\n| summarize totalAmount=sum(amount), totalQuantity=sum(quantity), eventCount=count() by status\n| project status, totalAmount, totalQuantity, eventCount\n| render columnchart",
      "id": "c97c1311-1497-45d1-9a7f-b2b651e11a33",
      "usedVariables": [
        "_Base",
        "_Date"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e5d28373-a861-4a5b-a653-6fc42c3ec443"
      },
      "text": "_Base\n| summarize avgSatisfaction=avg(toint(customerSatisfaction)), eventCount=count() by paymentMethod\n| project paymentMethod, avgSatisfaction, eventCount\n| render table",
      "id": "ddc20211-fd31-440e-bfdc-a314693cddb5",
      "usedVariables": [
        "_Base",
        "_Date"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e5d28373-a861-4a5b-a653-6fc42c3ec443"
      },
      "text": "_Base\n| summarize totalAmount=sum(amount), eventCount=count() by currency\n| top 10 by totalAmount desc\n| project currency, totalAmount, eventCount\n| render columnchart",
      "id": "27ef7d2f-c0aa-415d-9322-77603a1b756c",
      "usedVariables": [
        "_Base",
        "_Date"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e5d28373-a861-4a5b-a653-6fc42c3ec443"
      },
      "text": "_Base\n| summarize totalAmount=sum(amount), totalQuantity=sum(quantity) by bin(eventTime, 7d)\n| project eventTime, totalAmount, totalQuantity\n| render linechart",
      "id": "75976e21-d553-4973-9f22-6ec525812f87",
      "usedVariables": [
        "_Base",
        "_Date"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e5d28373-a861-4a5b-a653-6fc42c3ec443"
      },
      "text": "Silver_CustomerEvents",
      "id": "018c4009-7a46-4909-99dc-7d71484196f5",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e5d28373-a861-4a5b-a653-6fc42c3ec443"
      },
      "text": "table('Silver_CustomerEvents','hotcache')| where column_ifexists( _Date,ingestion_time()) between(_startTime.._endTime)",
      "id": "f6f29a3f-2de7-4229-beda-c6271cc4bfac",
      "usedVariables": [
        "_Date",
        "_endTime",
        "_startTime"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e5d28373-a861-4a5b-a653-6fc42c3ec443"
      },
      "text": "_schema| union (print ColumnName='ingestion_time()',ColumnType='datetime')| where ColumnType =='datetime'| project ColumnName",
      "id": "de54d064-f80a-4674-9aaa-369d05385f9a",
      "usedVariables": [
        "_schema"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e5d28373-a861-4a5b-a653-6fc42c3ec443"
      },
      "text": "_BaseTable| getschema",
      "id": "012d56a8-5710-46e2-ac8b-07bf9d644b9f",
      "usedVariables": [
        "_BaseTable"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e5d28373-a861-4a5b-a653-6fc42c3ec443"
      },
      "text": "let TimeRange=toscalar(_Base | summarize Start=min(column_ifexists(_Date,ingestion_time())),End=max(column_ifexists(_Date,ingestion_time()))| project totimespan(End - Start));let Bin=case(TimeRange > 7d,1d,TimeRange> 1d,1h,TimeRange>6h,10m,1m);_Base| summarize Rows=count() by bin(column_ifexists(_Date,ingestion_time()),Bin)",
      "id": "ae6efa34-80ef-4f28-89cd-452767198be0",
      "usedVariables": [
        "_Base",
        "_Date"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e5d28373-a861-4a5b-a653-6fc42c3ec443"
      },
      "text": "_schema| project ColumnName,ColumnType",
      "id": "e8ed6baf-c877-4914-96c6-6a45e5725645",
      "usedVariables": [
        "_schema"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "e5d28373-a861-4a5b-a653-6fc42c3ec443"
      },
      "text": "_Base| take 100",
